// TEAS Prep — data model
// Single-user personal study app. See plan: can-you-build-a-linked-hellman.md

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Section {
  READING
  MATH
  SCIENCE
  ENGLISH
}

enum QuestionType {
  SINGLE
  MULTI
  FILL_BLANK
  ORDERED
  HOT_SPOT
}

enum QuestionSource {
  original
  nursehub
  imported
}

enum AttemptMode {
  DIAGNOSTIC
  PRACTICE
  MOCK
  FLASHCARD
}

enum TaskKind {
  STUDY
  DRILL
  TEST
  FLASHCARD
  REVIEW
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())

  attempts   Attempt[]
  plans      StudyPlan[]
  reviews    CardReview[]
  questions  Question[]  @relation("UserQuestions")
  flashcards Flashcard[] @relation("UserFlashcards")
}

model Question {
  id          String         @id @default(cuid())
  section     Section
  topic       String
  subtopic    String?
  difficulty  Int            @default(2) // 1=easy, 2=medium, 3=hard
  type        QuestionType   @default(SINGLE)
  stem        String
  options     Json // string[] (empty for FILL_BLANK)
  correct     Json // index[] for SINGLE/MULTI/HOT_SPOT, string[] for FILL_BLANK, order[] for ORDERED
  explanation String?
  images      Json? // string[] of asset paths
  hotspots    Json? // [{ x, y, w, h, label }] when type = HOT_SPOT
  source      QuestionSource @default(original)
  attribution String?
  ownerId     String? // null = global shippable seed; set = private import
  owner       User?          @relation("UserQuestions", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  attemptItems AttemptItem[]

  @@index([section, topic])
  @@index([ownerId])
}

model Attempt {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode       AttemptMode
  config     Json? // { sections, counts, perTopic, timeLimits, ... }
  startedAt  DateTime    @default(now())
  finishedAt DateTime?
  scorePct   Float?

  items AttemptItem[]

  @@index([userId, mode])
}

model AttemptItem {
  id         String   @id @default(cuid())
  attemptId  String
  attempt    Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selected   Json? // user's answer (shape depends on question type)
  isCorrect  Boolean?
  timeMs     Int?
  flagged    Boolean  @default(false)
  orderIndex Int      @default(0)

  @@index([attemptId])
  @@index([questionId])
}

model StudyPlan {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  testDate     DateTime
  hoursPerWeek Int
  createdAt    DateTime   @default(now())
  weeks        PlanWeek[]

  @@index([userId])
}

model PlanWeek {
  id        String     @id @default(cuid())
  planId    String
  plan      StudyPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  weekIndex Int
  focus     String?
  tasks     PlanTask[]

  @@index([planId])
}

model PlanTask {
  id          String   @id @default(cuid())
  weekId      String
  week        PlanWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  dayOfWeek   Int // 0=Mon .. 6=Sun
  kind        TaskKind
  section     Section?
  topic       String?
  label       String
  targetCount Int?
  durationMin Int?
  done        Boolean  @default(false)

  @@index([weekId])
}

model Flashcard {
  id        String       @id @default(cuid())
  topic     String
  front     String
  back      String
  source    String       @default("original")
  ownerId   String?
  owner     User?        @relation("UserFlashcards", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  reviews   CardReview[]

  @@index([topic])
  @@index([ownerId])
}

model CardReview {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId         String
  card           Flashcard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  ease           Float     @default(2.5)
  intervalDays   Int       @default(0)
  reps           Int       @default(0)
  lapses         Int       @default(0)
  dueDate        DateTime  @default(now())
  lastReviewedAt DateTime?

  @@unique([userId, cardId])
  @@index([userId, dueDate])
}
