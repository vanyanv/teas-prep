# ── TEAS Prep environment (template) ───────────────────────────────────
# Copy to .env and fill in values.

# Neon Postgres pooled connection string, e.g.
# postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=""

# ── Clerk (authentication + billing) ────────────────────────────────────
# From the Clerk Dashboard → API keys. Use pk_test_/sk_test_ keys until launch.
# In local dev these may be left empty: Clerk runs in keyless mode and prints
# a claim link in the terminal.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Where the Clerk components live and where users land afterward.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL="/welcome"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/today"

# Clerk webhooks (Dashboard → Webhooks → endpoint /api/webhooks/clerk).
# Needed for subscription lifecycle analytics; access control works without it.
CLERK_WEBHOOK_SIGNING_SECRET=""

# ── Cloudflare R2 (science diagram assets) ──────────────────────────────
# Bucket holding adapted diagram PNGs. Only the upload script needs the
# credentials; the app reads assets over plain HTTPS from the public base URL.

# Cloudflare dashboard → R2 → account ID (also embedded in the endpoint).
R2_ACCOUNT_ID="af403acbb413064044dd1a6ad3c1ddeb"
R2_ENDPOINT="https://af403acbb413064044dd1a6ad3c1ddeb.r2.cloudflarestorage.com"
R2_BUCKET=""

# R2 → Manage R2 API Tokens → Create API token, "Object Read & Write" scoped
# to the bucket above. Secrets: never commit real values, set in Vercel too.
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Public read URL for the bucket, NO trailing slash. Prefer a custom domain
# (e.g. https://assets.example.com); the r2.dev dev URL is rate-limited and
# not meant for production. Client components read this, so it must be public.
NEXT_PUBLIC_R2_PUBLIC_BASE_URL=""

# Master billing switch. Leave unset (or anything but "true") to run the
# product fully unlocked: no paywalls, no upgrade prompts, no checkout.
# Set to "true" only after Clerk Billing is enabled and the `pro` plan
# ($4.99/mo) exists in the dashboard — see docs/clerk-billing-setup.md.
BILLING_ENABLED=""
